# ================= FPGA build artifacts (Libero-generated; regenerated by *.tcl) =================
# Whole Libero projects (synth/P&R/component output -- 100s of MB each, regenerated by create_fresh_project.tcl)
mpfs/fpga/libero_vm/
mpfs/fpga/libero_nl/
mpfs/fpga/libero_fresh/
mpfs/fpga/libero_tdest/
mpfs/fpga/libero_corefft/
mpfs/fpga/libero_corefft256/
mpfs/fpga/libero_corefft_vm/
mpfs/fpga/libero_ffv/
mpfs/fpga/libero_ffv_gbxfix_bak/
mpfs/fpga/baselines_backup_*/
mpfs/fpga/*.stdout.txt
mpfs/host/jtag_full/*.run.gdb
# Generated IP / MSS / HSS component output
mpfs/fpga/component/
mpfs/fpga/mss_min/
mpfs/fpga/mss_es/
mpfs/fpga/mss_component/
mpfs/fpga/mss_nodll/
mpfs/fpga/hss/
# Boot-mode programmer output
mpfs/fpga/bm0/
mpfs/fpga/bm1/
# HLS generated RTL (keep the .cpp / config.tcl / Makefile sources, drop the output)
mpfs/fpga/hls_*/hls_output/
# Sim build output (keep *.v / *.do)
mpfs/fpga/sim/work/
mpfs/fpga/sim/transcript
mpfs/fpga/sim/*.wlf
mpfs/fpga/sim/vsim_stacktrace.vstf
# Scratch / temp / wrappers
mpfs/fpga/_*.out
mpfs/fpga/_*.txt
mpfs/fpga/_*.bat
mpfs/fpga/hls_*/_*
mpfs/fpga/hls_*/*.bat

# libero_sar: keep ONLY the firmware source tree; drop the Libero project + softconsole build
mpfs/fpga/libero_sar/**
!mpfs/fpga/libero_sar/
!mpfs/fpga/libero_sar/softconsole/
!mpfs/fpga/libero_sar/softconsole/mpfs-hal-ddr-demo/
!mpfs/fpga/libero_sar/softconsole/mpfs-hal-ddr-demo/src/
!mpfs/fpga/libero_sar/softconsole/mpfs-hal-ddr-demo/src/**
mpfs/fpga/libero_sar/softconsole/mpfs-hal-ddr-demo/Icicle-Kit-*/
mpfs/fpga/libero_sar/softconsole/mpfs-hal-ddr-demo/**/*.o
mpfs/fpga/libero_sar/softconsole/mpfs-hal-ddr-demo/**/*.elf

# ================= Host: staged inputs + goldens (large; regenerated by serialize_inputs.py) ======
mpfs/host/jtag_stage/
mpfs/host/jtag_stage_small/
*.npy

# ================= Archive (stale experiments; kept locally, never uploaded) =====================
archive/

# ================= Office / misc temp =============================================================
~$*
*.docx

# ================= Vendor reference docs (licensed; not for public redistribution) ===============
reference/

# ================= Host: staged signal data + JTAG dumps (large, generated) ======================
mpfs/host/jtag_full/*.bin
mpfs/host/jtag_full/sigchunk_*
mpfs/host/jtag_full/sig.bin
mpfs/host/jtag_full/readback*
mpfs/host/jtag_full/out*.bin
mpfs/host/*.log
mpfs/host/*.docx

# ================= Sim vectors/dumps (keep *.v / *.do; drop big generated data) ===================
mpfs/fpga/sim/*.wlf
mpfs/fpga/sim/*.vcd
mpfs/fpga/sim/_*.log
mpfs/fpga/sim/fft_vectors/*.bin

# ===== SAR / PolarFire FPGA + firmware build artifacts (regeneratable, 100s of MB) =====
